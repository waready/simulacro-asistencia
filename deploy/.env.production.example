SIMULACRO_APP_NAME=Simulacro API
SIMULACRO_APP_VERSION=1.0.0
SIMULACRO_STORAGE_BACKEND=mysql
SIMULACRO_API_KEY=cambia_este_token_largo
SIMULACRO_DEFAULT_LIMIT=20
SIMULACRO_MAX_LIMIT=100
SIMULACRO_DB_HOST=127.0.0.1
SIMULACRO_DB_PORT=3306
SIMULACRO_DB_NAME=simulacro_aulas
SIMULACRO_DB_USER=root
SIMULACRO_DB_PASSWORD=
SIMULACRO_DB_CHARSET=utf8mb4
SIMULACRO_DB_STUDENTS_TABLE=simulacro_alumnos
SIMULACRO_DB_EVENT_TABLE=simulacro_evento
SIMULACRO_DB_AUTO_SEED=false
SIMULACRO_MYSQL_CACHE_TTL_SECONDS=60
SIMULACRO_CORS_ORIGINS=https://tu-laravel.com
SIMULACRO_CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
SIMULACRO_CORS_HEADERS=Authorization,Content-Type,X-API-Key
SIMULACRO_CORS_ALLOW_CREDENTIALS=false
